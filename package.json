{
  "name": "dotaroulette",
  "version": "1.0.0",
  "description": "DotaRoulette — spin the wheel to pick roles & heroes for your Dota 2 party!",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node server/index.js",
    "dev:client": "npx vite client --port 5173",
    "build": "npx vite build client --outDir dist --emptyOutDir",
    "start": "node server/index.js",
    "preview": "npm run build && npm start"
  },
  "dependencies": {
    "express": "^4.21.0",
    "better-sqlite3": "^11.6.0",
    "jsonwebtoken": "^9.0.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "vite": "^6.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
